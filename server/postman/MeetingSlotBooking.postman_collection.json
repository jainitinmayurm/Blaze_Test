{
  "info": {
    "name": "Meeting Slot Booking System",
    "description": "Complete API collection for the Meeting Slot Booking System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Test User\", \"email\": \"test@blaze.com\", \"password\": \"Test@123\", \"timezone\": \"Asia/Kolkata\"}"
            }
          }
        },
        {
          "name": "Login (Admin)",
          "event": [{ "listen": "test", "script": { "exec": ["var json = pm.response.json(); pm.collectionVariables.set('token', json.token);"] } }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"email\": \"admin@blaze.com\", \"password\": \"Admin@123\"}" }
          }
        },
        {
          "name": "Login (Alice)",
          "event": [{ "listen": "test", "script": { "exec": ["var json = pm.response.json(); pm.collectionVariables.set('token', json.token);"] } }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"email\": \"alice@blaze.com\", \"password\": \"User@123\"}" }
          }
        },
        {
          "name": "Get Current User",
          "request": { "method": "GET", "url": "{{baseUrl}}/auth/me" }
        },
        {
          "name": "List All Users",
          "request": { "method": "GET", "url": "{{baseUrl}}/auth/users" }
        }
      ]
    },
    {
      "name": "Meetings",
      "item": [
        {
          "name": "Create Meeting (Online)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/meetings",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"Team Sync\", \"agenda\": \"Weekly team sync\", \"type\": \"online\", \"start_time\": \"2026-05-20T10:00:00Z\", \"end_time\": \"2026-05-20T11:00:00Z\", \"participants\": [2, 3]}"
            }
          }
        },
        {
          "name": "Create Meeting (Offline)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/meetings",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"Design Review\", \"agenda\": \"Review mockups\", \"type\": \"offline\", \"start_time\": \"2026-05-21T14:00:00Z\", \"end_time\": \"2026-05-21T15:00:00Z\", \"room_id\": 1, \"participants\": [2, 3, 4]}"
            }
          }
        },
        {
          "name": "List Meetings",
          "request": { "method": "GET", "url": "{{baseUrl}}/meetings" }
        },
        {
          "name": "Get Meeting Details",
          "request": { "method": "GET", "url": "{{baseUrl}}/meetings/1" }
        },
        {
          "name": "Update Meeting",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/meetings/4",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"title\": \"Updated Design Sync\", \"start_time\": \"2026-05-22T10:00:00Z\", \"end_time\": \"2026-05-22T11:00:00Z\"}" }
          }
        },
        {
          "name": "Cancel Meeting",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/meetings/1",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"reason\": \"No longer needed\"}" }
          }
        },
        {
          "name": "Respond to Meeting",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/meetings/4/respond",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"response\": \"Accepted\"}" }
          }
        }
      ]
    },
    {
      "name": "Availability",
      "item": [
        {
          "name": "Get Free Slots",
          "request": { "method": "GET", "url": "{{baseUrl}}/availability?participants=2,3&date=2026-05-20&duration=30" }
        },
        {
          "name": "Get Free Slots with Room",
          "request": { "method": "GET", "url": "{{baseUrl}}/availability?participants=2,3&date=2026-05-20&room_id=1&duration=60" }
        }
      ]
    },
    {
      "name": "Rooms",
      "item": [
        {
          "name": "List Rooms",
          "request": { "method": "GET", "url": "{{baseUrl}}/rooms" }
        },
        {
          "name": "Create Room (Admin)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/rooms",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"name\": \"Sky Lounge\", \"capacity\": 15, \"equipment\": \"[\\\"Projector\\\", \\\"Sound System\\\"]\", \"location\": \"Rooftop\"}" }
          }
        },
        {
          "name": "Room Availability",
          "request": { "method": "GET", "url": "{{baseUrl}}/rooms/1/availability?date=2026-05-20" }
        }
      ]
    },
    {
      "name": "Calendar",
      "item": [
        {
          "name": "Calendar Feed",
          "request": { "method": "GET", "url": "{{baseUrl}}/calendar?from=2026-05-01T00:00:00Z&to=2026-05-31T23:59:59Z" }
        }
      ]
    },
    {
      "name": "Reports",
      "item": [
        {
          "name": "Meeting Summary",
          "request": { "method": "GET", "url": "{{baseUrl}}/reports/summary" }
        },
        {
          "name": "Room Utilization",
          "request": { "method": "GET", "url": "{{baseUrl}}/reports/room-utilization" }
        },
        {
          "name": "No-Shows",
          "request": { "method": "GET", "url": "{{baseUrl}}/reports/no-shows" }
        }
      ]
    }
  ]
}
